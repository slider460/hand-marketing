---
import Base from '../layouts/Base.astro';
const services = [
  { t: 'Event', c: 'var(--purple)', href: '/event' },
  { t: 'Creative & Design', c: 'var(--pink)', href: '/creativedesign' },
  { t: 'Video Production', c: 'var(--orange)', href: '/videoproduction' },
  { t: 'Digital', c: 'var(--green)', href: '/digital' },
  { t: '3D Mapping', c: 'var(--purple)', href: '/3dmapping' },
  { t: 'Print & Production', c: 'var(--orange)', href: '/printandproduction' },
  { t: 'BTL', c: 'var(--pink)', href: '/btl' },
];
---
<Base>
  <header class="hd">
    <div class="wrap hd__in">
      <a class="brand" href="/" aria-label="Hand Marketing">
        <span class="cube" aria-hidden="true"></span>
        <b>HAND MARKETING</b>
      </a>
      <nav class="nav">
        <a href="/project">Проекты</a><a href="/about">О нас</a>
        <a href="/clients">Клиенты</a><a href="/contacts">Контакты</a>
      </nav>
    </div>
  </header>

  <section class="hero">
    <div class="wrap hero__in">
      <p class="eyebrow" data-anim>Рекламное агентство полного цикла · с 2012</p>
      <h1 class="title">
        <span class="line" data-anim>Делаем</span>
        <span class="line" data-anim>маркетинг,<span class="accent"> который видно</span></span>
      </h1>
      <ul class="svc">
        {services.map((s) => (
          <li data-anim><a href={s.href} style={`--c:${s.c}`}><i></i>{s.t}</a></li>
        ))}
      </ul>
      <div class="cta" data-anim>
        <button id="reel" class="btn">▶ Смотреть showreel</button>
        <a class="btn btn--ghost" href="/project">Все проекты →</a>
      </div>
    </div>
    <div class="orbit" aria-hidden="true"></div>
  </section>

  <style>
    .hd{position:sticky;top:0;z-index:50;background:rgba(255,255,255,.8);backdrop-filter:blur(12px);border-bottom:1px solid var(--line)}
    .hd__in{display:flex;align-items:center;justify-content:space-between;height:64px}
    .brand{display:flex;align-items:center;gap:11px}
    .brand b{font-family:var(--f-head);font-weight:800;font-size:15px;letter-spacing:.04em;color:var(--ink)}
    .cube{width:26px;height:26px;border-radius:6px;background:
      conic-gradient(from 45deg,var(--green),var(--orange),var(--pink),var(--purple),var(--green));
      animation:spin 8s linear infinite}
    @keyframes spin{to{transform:rotate(360deg)}}
    @media(prefers-reduced-motion:reduce){.cube{animation:none}}
    .nav{display:flex;gap:26px;font-weight:500;font-size:15px}
    .nav a{color:var(--body);transition:color .2s}.nav a:hover{color:var(--ink)}
    @media(max-width:720px){.nav{display:none}}

    .hero{position:relative;overflow:hidden;padding:clamp(48px,9vw,110px) 0 clamp(60px,10vw,120px)}
    .eyebrow{font-family:var(--f-head);font-weight:700;font-size:13px;letter-spacing:.14em;text-transform:uppercase;color:var(--dim);margin:0 0 26px}
    .title{font-weight:800;font-size:clamp(44px,9vw,104px);line-height:.98;color:var(--ink);margin:0 0 44px}
    .title .line{display:block;overflow:hidden}
    .title .accent{background:linear-gradient(92deg,var(--green),var(--orange) 38%,var(--pink) 70%,var(--purple));
      -webkit-background-clip:text;background-clip:text;color:transparent}
    .svc{list-style:none;margin:0 0 44px;padding:0;display:flex;flex-wrap:wrap;gap:10px 28px;max-width:760px}
    .svc a{display:inline-flex;align-items:center;gap:11px;font-family:var(--f-head);font-weight:700;
      font-size:clamp(20px,3.4vw,30px);color:var(--ink);transition:transform .3s var(--ease),color .3s}
    .svc i{width:13px;height:13px;border-radius:4px;background:var(--c);transition:transform .3s var(--ease)}
    .svc a:hover{color:var(--c)}.svc a:hover i{transform:scale(1.5) rotate(12deg)}
    .cta{display:flex;flex-wrap:wrap;gap:14px}
    .btn{font-family:var(--f-head);font-weight:700;font-size:15px;border:0;cursor:pointer;
      padding:16px 26px;border-radius:999px;background:var(--ink);color:#fff;transition:transform .25s var(--ease),box-shadow .25s}
    .btn:hover{transform:translateY(-2px);box-shadow:0 16px 36px -16px rgba(0,0,0,.5)}
    .btn--ghost{background:transparent;color:var(--ink);border:2px solid var(--line)}
    .btn--ghost:hover{border-color:var(--ink);box-shadow:none}
    .orbit{position:absolute;right:-12%;top:-10%;width:min(640px,70vw);aspect-ratio:1;z-index:-1;
      background:conic-gradient(from 0deg,var(--green),var(--orange),var(--pink),var(--purple),var(--green));
      filter:blur(80px);opacity:.16;border-radius:50%;animation:spin 26s linear infinite}

    [data-anim]{opacity:0;transform:translateY(22px)}
  </style>

  <script>
    import { animate, stagger } from 'motion';
    const items = document.querySelectorAll('[data-anim]');
    const reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (reduce) {
      items.forEach((el) => { (el as HTMLElement).style.opacity = '1'; (el as HTMLElement).style.transform = 'none'; });
    } else {
      animate(items, { opacity: 1, transform: 'translateY(0px)' },
        { duration: .8, delay: stagger(.07), easing: [.16, 1, .3, 1] });
    }
    // magnetic CTA
    document.querySelectorAll<HTMLElement>('.btn').forEach((b) => {
      b.addEventListener('pointermove', (e) => {
        const r = b.getBoundingClientRect();
        b.style.transform = `translate(${(e.clientX - r.left - r.width / 2) / 6}px, ${(e.clientY - r.top - r.height / 2) / 6}px)`;
      });
      b.addEventListener('pointerleave', () => { b.style.transform = ''; });
    });
  </script>
</Base>
