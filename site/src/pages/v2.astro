---
import Base from '../layouts/Base.astro';
const services = [
  { t: 'Event', c: '#673A7E', href: '/event' },
  { t: 'Creative & Design', c: '#C12164', href: '/creativedesign' },
  { t: 'Video Production', c: '#CF6F19', href: '/videoproduction' },
  { t: 'Digital', c: '#5E9A2E', href: '/digital' },
  { t: '3D Mapping', c: '#7E3FA0', href: '/3dmapping' },
  { t: 'Print & Production', c: '#E08A2B', href: '/printandproduction' },
  { t: 'BTL', c: '#D6357E', href: '/btl' },
];
---
<Base title="Hand Marketing — рекламное агентство полного цикла">
  <header class="hd">
    <div class="wrap hd__in">
      <a class="brand" href="/"><img src="/logo-cube.png" alt="" width="34" height="34" /><b>HAND MARKETING</b></a>
      <nav class="nav"><a href="/project">Проекты</a><a href="/about">О нас</a><a href="/clients">Клиенты</a><a href="/contacts">Контакты</a></nav>
      <a class="hd__cta" href="/contacts">Обсудить проект</a>
    </div>
  </header>

  <main class="wrap">
    <section class="bento">
      <!-- фичер -->
      <a class="tile feature" href="/project" data-t>
        <span class="kick">Рекламное агентство полного цикла · с 2012</span>
        <h1>Идеи, которые<br><span>работают на бренд</span></h1>
        <span class="more">Смотреть кейсы <i>→</i></span>
        <img class="feature__cube" src="/logo-cube.png" alt="" width="120" height="120" />
      </a>

      <!-- showreel -->
      <button class="tile reel" id="reel" data-t>
        <span class="play"></span>
        <span class="reel__t">Showreel<br><small>2 мин · 40+ проектов</small></span>
      </button>

      <!-- статы -->
      <div class="tile stat" data-t><b data-count="10">0</b><span>лет на рынке<br>с 2012 года</span></div>
      <div class="tile stat stat--alt" data-t><b data-count="40">0</b><span>реализованных<br>кейсов</span></div>

      <!-- услуги -->
      {services.map((s) => (
        <a class="tile svc" href={s.href} style={`--c:${s.c}`} data-t>
          <span class="svc__t">{s.t}</span>
          <span class="svc__arr">→</span>
        </a>
      ))}
    </section>
  </main>

  <style>
    .hd{position:sticky;top:0;z-index:50;background:rgba(255,255,255,.86);backdrop-filter:blur(12px);border-bottom:1px solid var(--line)}
    .hd__in{display:flex;align-items:center;gap:24px;height:66px}
    .brand{display:flex;align-items:center;gap:10px;margin-right:auto}
    .brand b{font-family:var(--f-head);font-weight:800;font-size:15px;letter-spacing:.04em;color:var(--ink)}
    .nav{display:flex;gap:24px;font-weight:500;font-size:15px}
    .nav a{color:var(--body)}.nav a:hover{color:var(--ink)}
    .hd__cta{font-family:var(--f-head);font-weight:700;font-size:14px;color:#fff;background:var(--ink);padding:11px 18px;border-radius:999px;transition:transform .2s var(--ease)}
    .hd__cta:hover{transform:translateY(-2px)}
    @media(max-width:820px){.nav,.hd__cta{display:none}}

    .bento{display:grid;gap:14px;grid-template-columns:repeat(4,1fr);grid-auto-rows:minmax(116px,auto);margin:22px 0 40px}
    .tile{position:relative;border-radius:20px;overflow:hidden;border:1px solid var(--line);padding:24px;
      display:flex;flex-direction:column;justify-content:flex-end;background:var(--soft);color:var(--ink);
      transition:transform .35s var(--ease),box-shadow .35s var(--ease)}
    .tile:hover{transform:translateY(-4px);box-shadow:0 24px 50px -28px rgba(20,23,28,.35)}
    .feature{grid-column:span 2;grid-row:span 2;background:var(--ink);color:#fff;justify-content:space-between}
    .feature .kick{font-family:var(--f-head);font-weight:700;font-size:12.5px;letter-spacing:.12em;text-transform:uppercase;color:rgba(255,255,255,.55)}
    .feature h1{font-family:var(--f-head);font-weight:800;font-size:clamp(30px,4.4vw,52px);line-height:1.02;color:#fff;margin:18px 0}
    .feature h1 span{background:linear-gradient(92deg,#7ec24a,#f0902f 40%,#e0427e 72%,#8a52ad);-webkit-background-clip:text;background-clip:text;color:transparent}
    .feature .more{font-family:var(--f-head);font-weight:700;font-size:15px;color:#fff;display:inline-flex;gap:8px;align-items:center}
    .feature .more i{transition:transform .3s var(--ease)}
    .feature:hover .more i{transform:translateX(6px)}
    .feature__cube{position:absolute;right:18px;top:18px;width:clamp(64px,9vw,120px);height:auto;opacity:.95;
      animation:float 6s ease-in-out infinite}
    @keyframes float{50%{transform:translateY(-10px) rotate(6deg)}}

    .reel{grid-column:span 2;cursor:pointer;border:0;text-align:left;
      background:linear-gradient(120deg,#1b1f27,#2a2030);color:#fff;flex-direction:row;align-items:center;gap:18px;justify-content:flex-start}
    .reel .play{flex:0 0 auto;width:60px;height:60px;border-radius:50%;background:var(--yellow);position:relative}
    .reel .play::after{content:"";position:absolute;left:54%;top:50%;transform:translate(-50%,-50%);border-style:solid;border-width:11px 0 11px 18px;border-color:transparent transparent transparent #14171C}
    .reel__t{font-family:var(--f-head);font-weight:800;font-size:22px}
    .reel__t small{font-family:var(--f-body);font-weight:500;font-size:13px;color:rgba(255,255,255,.6)}

    .stat{align-items:flex-start}
    .stat b{font-family:var(--f-head);font-weight:800;font-size:clamp(38px,5vw,56px);line-height:1;color:var(--ink)}
    .stat b::after{content:"+";color:var(--pink)}
    .stat span{font-size:13.5px;color:var(--dim);margin-top:8px}
    .stat--alt b::after{color:var(--green)}

    .svc{justify-content:space-between;flex-direction:row;align-items:center;background:var(--c);color:#fff;border:0}
    .svc__t{font-family:var(--f-head);font-weight:700;font-size:clamp(16px,1.5vw,20px)}
    .svc__arr{font-size:18px;opacity:.7;transition:transform .3s var(--ease)}
    .svc:hover .svc__arr{transform:translate(4px,-4px);opacity:1}

    @media(max-width:900px){.bento{grid-template-columns:repeat(2,1fr)}.feature,.reel{grid-column:span 2}}
    @media(max-width:560px){.bento{grid-template-columns:1fr}.feature,.reel,.svc,.stat{grid-column:span 1}.feature{grid-row:auto}}

    [data-t]{opacity:0;transform:translateY(18px) scale(.98)}
  </style>

  <script>
    import { animate, stagger, inView } from 'motion';
    const reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;
    const tiles = document.querySelectorAll('[data-t]');
    if (reduce) tiles.forEach((t) => Object.assign((t as HTMLElement).style, { opacity: '1', transform: 'none' }));
    else animate(tiles, { opacity: 1, transform: 'translateY(0px) scale(1)' }, { duration: .7, delay: stagger(.05), easing: [.16, 1, .3, 1] });
    // count-up
    document.querySelectorAll<HTMLElement>('[data-count]').forEach((el) => {
      const to = +el.dataset.count!;
      if (reduce) { el.textContent = String(to); return; }
      inView(el, () => {
        animate(0, to, { duration: 1.4, easing: [.16, 1, .3, 1], onUpdate: (v) => (el.textContent = String(Math.round(v))) });
      }, { amount: 0.6 });
    });
  </script>
</Base>
